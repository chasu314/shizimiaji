<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>Ice Catch Challenge</title>
<style>
    body {
        margin: 0;
        overflow: hidden;
        font-family: 'Arial', sans-serif;
        background: linear-gradient(to bottom, #87ceeb, #ffffff);
    }

    canvas {
        display: block;
        margin: auto;
        background: rgba(255,255,255,0.6);
        box-shadow: 0 0 20px rgba(0,0,0,0.2);
    }

    #startScreen {
        position: absolute;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.7);
        color: white;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    button {
        padding: 10px 20px;
        font-size: 18px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
        background: #ff69b4;
        color: white;
    }

    button:hover {
        background: #ff1493;
    }
</style>
</head>
<body>

<div id="startScreen">
    <h1>🍦 Ice Catch Challenge 🍦</h1>
    <p>コーンを動かしてアイスをキャッチしよう！</p>
    <button onclick="startGame()">START</button>
</div>

<canvas id="gameCanvas"></canvas>

<script>
const canvas = document.getElementById("gameCanvas");
const ctx = canvas.getContext("2d");
canvas.width = 400;
canvas.height = 600;

let cone, iceCreams, score, missed, level, speedMultiplier;
let gameRunning = false;

function initGame() {
    cone = { x: 180, y: 520, width: 60, height: 70, speed: 8 };
    iceCreams = [];
    score = 0;
    missed = 0;
    level = 1;
    speedMultiplier = 1;
}

function startGame() {
    document.getElementById("startScreen").style.display = "none";
    initGame();
    gameRunning = true;
    spawnIce();
    update();
}

function spawnIce() {
    if (!gameRunning) return;
    iceCreams.push({
        x: Math.random() * (canvas.width - 30),
        y: -30,
        size: 30,
        speed: (2 + Math.random() * 2) * speedMultiplier,
        color: ["pink","lightblue","yellow","lightgreen"][Math.floor(Math.random()*4)]
    });
    setTimeout(spawnIce, 1000 - level*50);
}

function drawCone() {
    ctx.fillStyle = "#d2691e";
    ctx.beginPath();
    ctx.moveTo(cone.x, cone.y);
    ctx.lineTo(cone.x + cone.width / 2, cone.y + cone.height);
    ctx.lineTo(cone.x + cone.width, cone.y);
    ctx.closePath();
    ctx.fill();
}

function drawIce(ic) {
    ctx.fillStyle = ic.color;
    ctx.beginPath();
    ctx.arc(ic.x, ic.y, ic.size/2, 0, Math.PI*2);
    ctx.fill();
}

function update() {
    if (!gameRunning) return;

    ctx.clearRect(0, 0, canvas.width, canvas.height);

    drawCone();

    for (let i = 0; i < iceCreams.length; i++) {
        let ic = iceCreams[i];
        ic.y += ic.speed;
        drawIce(ic);

        if (
            ic.y + ic.size/2 > cone.y &&
            ic.x > cone.x &&
            ic.x < cone.x + cone.width
        ) {
            score++;
            iceCreams.splice(i,1);
            i--;
            if (score % 10 === 0) {
                level++;
                speedMultiplier += 0.2;
            }
        }
        else if (ic.y > canvas.height) {
            missed++;
            iceCreams.splice(i,1);
            i--;
        }
    }

    ctx.fillStyle = "#000";
    ctx.fillText("Score: " + score, 10, 20);
    ctx.fillText("Missed: " + missed, 10, 40);
    ctx.fillText("Level: " + level, 10, 60);

    if (missed >= 5) {
        gameRunning = false;
        alert("ゲームオーバー！ Score: " + score);
        location.reload();
    }

    requestAnimationFrame(update);
}

document.addEventListener("keydown", e => {
    if (e.key === "ArrowLeft" && cone.x > 0) cone.x -= cone.speed;
    if (e.key === "ArrowRight" && cone.x < canvas.width - cone.width)
        cone.x += cone.speed;
});

canvas.addEventListener("mousemove", e => {
    const rect = canvas.getBoundingClientRect();
    cone.x = e.clientX - rect.left - cone.width/2;
});

</script>

</body>
</html>
